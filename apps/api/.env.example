APP_NAME=ZB Vaka API
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://user:password@host:5432/zbvaka
REDIS_URL=redis://default:password@host:6379
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:3000,https://your-production-web.vercel.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
FRONTEND_URL=https://your-production-web.vercel.app
SEED_ADMIN_EMAIL=admin@zbvaka.co.zw
SEED_ADMIN_PASSWORD=Admin123!
